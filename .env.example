# RMBG-2.0 为 Hugging Face 受条款保护模型，二选一：

# 方式 A：在线下载（需先在 https://huggingface.co/briaai/RMBG-2.0 同意条款）
HF_TOKEN=hf_your_token_here

# 方式 B：仅使用本地模型（推荐生产环境，需先有 models/RMBG-2.0/onnx/model.onnx）
# MODEL_LOCAL_ONLY=true
# MODEL_LOCAL_PATH=/absolute/path/to/RMBG-2.0

# 可选：代理 / 镜像
# MODEL_PROXY_URL=http://user:pass@host:3128
# HF_ENDPOINT=https://hf-mirror.com/
